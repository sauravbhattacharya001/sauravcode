function unused_helper
    return "never called"

function undocumented x
    return x * 2

function complexLogic x
    if x == 1
        print "one"
    elif x == 2
        print "two"
    elif x == 3
        print "three"
    elif x == 4
        print "four"
    elif x == 5
        print "five"
    elif x == 6
        print "six"

function simple_calc a b
    return a + b

# A well-documented function
function documented_func x y
    # Adds two values together
    return x + y

function caller_func x
    result = simple_calc(x, 1)
    result = undocumented(result)
    result = documented_func(result, 2)
    result = complexLogic(result)
    return result
