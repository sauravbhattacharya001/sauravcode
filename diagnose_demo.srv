# diagnose_demo.srv — Demonstrate sauravdiagnose capabilities
# Run: python sauravdiagnose.py diagnose_demo.srv

# A working function
function greet name
    print "Hello, " + name + "!"

# Test the working function
greet "World"

# A recursive factorial
function factorial n
    if n <= 1
        return 1
    return n * factorial(n - 1)

print factorial(5)

# Demonstrate safe list operations
items = [10, 20, 30]
print items[0]
print len(items)

print "diagnose_demo completed successfully!"
