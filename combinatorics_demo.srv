print "=== sort_by ==="
words = ["banana", "apple", "cherry", "date"]
sorted_words = sort_by (lambda x -> len(x)) words
print sorted_words

print "=== min_by / max_by ==="
shortest = min_by (lambda x -> len(x)) words
longest = max_by (lambda x -> len(x)) words
print shortest
print longest

print "=== partition ==="
nums = [1, 2, 3, 4, 5, 6, 7, 8]
parts = partition (lambda x -> x > 4) nums
print parts

print "=== rotate ==="
print rotate [1, 2, 3, 4, 5] 2
n = 0 - 1
print rotate [1, 2, 3, 4, 5] n

print "=== interleave ==="
print interleave [1, 3, 5] [2, 4, 6]

print "=== frequencies ==="
colors = ["red", "blue", "red", "green", "blue", "red"]
print frequencies colors

print "=== combinations ==="
print combinations [1, 2, 3] 2

print "=== permutations ==="
print permutations [1, 2, 3] 2