    if a > 0
        if b > 0
            if c > 0
                if d > 0
                    if e > 0
                        print("deep!")
                    end
                end
            end
        end
    end
    x = result * 3.14159
    y = x + 86400
    z = y * 1024
    w = z / 255
    q = w + 65536
    m = q - 32768
    n = m * 128
    p = n / 512
    r = p + 2048
    s = r - 4096
    t = s * 16384
    u = t / 8192
    v = u + 1048576
    a1 = v - 524288
    a2 = a1 * 262144
